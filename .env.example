# =============================================
# FRONTEND (Vite) — expostas ao cliente
# =============================================
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
# URL pública usada em links dentro de emails (sempre aponta para o app publicado).
# Se omitida, usa a URL de produção padrão definida em src/utils/appUrl.ts.
VITE_APP_URL=https://flow-lab.vercel.app

# =============================================
# BACKEND (Vercel Serverless / api/) — NUNCA expor no cliente
# =============================================

# Supabase (service role — bypassa RLS)
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# SMTP (envio de e-mails transacionais)
SMTP_HOST=smtp.exemplo.com
SMTP_PORT=587
SMTP_USER=no-reply@empresa.com
SMTP_PASS=your_smtp_password
SMTP_FROM=Sistema FlowLab <no-reply@empresa.com>

# Google Workspace — Admin SDK / Directory API (criação de alias)
# Service account com domain-wide delegation autorizada para o escopo
# https://www.googleapis.com/auth/admin.directory.user.alias
GOOGLE_SA_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_SA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_ADMIN_SUBJECT=admin@seudominio.com
GOOGLE_ALIAS_TARGET=conta-alvo@seudominio.com
GOOGLE_ALIAS_DOMAIN=seudominio.com

# Slack — link de convite compartilhado do workspace
SLACK_INVITE_URL=https://join.slack.com/t/seu-workspace/shared_invite/seu-token-de-convite

# Integração LAB-HUB (módulo Análises Clínicas / api/analises-clinicas/*)
# Comunicação server-to-server apenas — NUNCA expor no cliente.
# URL da API do LAB-HUB (destino do deliver-resultado e do deliver-coleta).
# Em dev: http://localhost:3333
LABHUB_API_URL=http://localhost:3333
# Chave que o LAB-HUB envia em Authorization: Bearer ... ao chamar receive-agendamento
# e get-disponibilidade. DEVE ser idêntica ao FLOWLAB_API_KEY do LAB-HUB.
FLOWLAB_API_KEY=senha-aleatoria-para-autenticacao
# Segredo HMAC-SHA256 dos webhooks de resultado e de coleta. DEVE ser idêntico ao
# FLOWLAB_WEBHOOK_SECRET do LAB-HUB (mesmo valor, nome diferente nos dois repos).
LABHUB_WEBHOOK_SECRET=segredo-aleatorio-para-verificacao
#
# Gatilho de status da coleta (migration 20260713120000): o banco chama o
# deliver-coleta automaticamente via pg_net quando a coleta muda de status. Os
# segredos NÃO ficam em env de processo — provisione no Supabase Vault (uma vez):
#   select vault.create_secret('<LABHUB_API_URL nas funções>/api/analises-clinicas/deliver-coleta', 'flowlab_deliver_coleta_url');
#   select vault.create_secret('<FLOWLAB_API_KEY>', 'flowlab_api_key');

# Umami Analytics (Hub de Aplicações — /api/umami)
# Credenciais de servidor: NUNCA expor no cliente e NUNCA versionar com valor real.
# O endpoint exige sessão do usuário com a permissão canManageIT.
UMAMI_BASE_URL=https://sua-instancia-umami/api
UMAMI_USER=usuario-de-leitura
UMAMI_PASS=senha-do-usuario
# Fuso usado quando o cliente não manda o dele. Default: America/Sao_Paulo
UMAMI_TIMEZONE=America/Sao_Paulo
# Tracker no navegador (públicos — vão no HTML da página)
VITE_UMAMI_TRACKER_SRC=https://sua-instancia-umami/script.js
VITE_UMAMI_WEBSITE_ID=uuid-do-site-no-umami
